#!/usr/bin/env bash
# ============================================================
# bootstrap.sh — automated setup for {{ manifest.name }} {{ manifest.version }}
# Generated by skill-mcp-protocol on {{ export_date }}
#
# Usage:
#   chmod +x bootstrap.sh
#   ./bootstrap.sh [--install-dir /absolute/path] [--no-register]
# ============================================================
set -euo pipefail

SKILL_NAME="{{ manifest.name }}"
SKILL_VERSION="{{ manifest.version }}"
RUNTIME_TYPE="{{ manifest.runtime.type }}"
ENTRYPOINT="{{ manifest.mcp.entrypoint }}"
TRANSPORT="{{ manifest.mcp.transport }}"

INSTALL_DIR="${1:-$(pwd)}"
REGISTER=true

for arg in "$@"; do
  case $arg in
    --install-dir=*) INSTALL_DIR="${arg#*=}" ;;
    --no-register)   REGISTER=false ;;
  esac
done

echo "=== skill-mcp-protocol bootstrap ==="
echo "Skill   : $SKILL_NAME $SKILL_VERSION"
echo "Target  : $INSTALL_DIR"
echo ""

# ── Step 1: Runtime check ──────────────────────────────────
{% if manifest.runtime.type == "python" %}
REQUIRED_PYTHON="{{ manifest.runtime.python_version or "3.10" }}"
if ! command -v python3 &>/dev/null; then
  echo "ERROR: python3 not found. Please install Python ${REQUIRED_PYTHON}+" >&2
  exit 1
fi
PYTHON_VERSION=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
echo "Found Python $PYTHON_VERSION"
{% elif manifest.runtime.type == "node" %}
if ! command -v node &>/dev/null; then
  echo "ERROR: node not found. Please install Node.js 18+." >&2
  exit 1
fi
echo "Found Node $(node --version)"
{% endif %}

# ── Step 2: Create virtual environment ────────────────────
{% if manifest.runtime.type == "python" %}
VENV_DIR="$INSTALL_DIR/.venv"
if [ -d "$VENV_DIR" ]; then
  echo "Existing .venv found — skipping creation."
else
  echo "Creating Python venv at $VENV_DIR ..."
  python3 -m venv "$VENV_DIR"
fi

VENV_PYTHON="$VENV_DIR/bin/python"
VENV_PIP="$VENV_DIR/bin/pip"

# Install / upgrade dependencies
echo "Installing dependencies ..."
"$VENV_PIP" install --upgrade pip --quiet
"$VENV_PIP" install -r "$INSTALL_DIR/requirements.txt" --quiet
echo "Dependencies installed."

{% elif manifest.runtime.type == "node" %}
echo "Installing Node dependencies ..."
cd "$INSTALL_DIR" && npm install --silent
VENV_PYTHON="node"  # placeholder for registration
{% else %}
VENV_PYTHON="{{ manifest.mcp.entrypoint }}"
{% endif %}

# ── Step 3: Register with hosts ───────────────────────────
if [ "$REGISTER" = true ]; then
  ENTRY_ABS="$INSTALL_DIR/$ENTRYPOINT"

  # -- Claude Code --
  CLAUDE_CFG="$HOME/.claude.json"
  if command -v python3 &>/dev/null && python3 -c "import json" 2>/dev/null; then
    python3 - << PYEOF
import json, pathlib, sys

cfg_path = pathlib.Path("$CLAUDE_CFG")
data = json.loads(cfg_path.read_text()) if cfg_path.exists() else {}
data.setdefault("mcpServers", {})["$SKILL_NAME"] = {
    "type":    "$TRANSPORT",
    "command": "$VENV_PYTHON",
    "args":    ["$ENTRY_ABS"],
    "env":     {},
}
cfg_path.write_text(json.dumps(data, indent=2))
print("Registered with Claude Code -> $CLAUDE_CFG")
PYEOF
  fi

  # -- Codex --
  CODEX_CFG="$HOME/.codex/config.toml"
  mkdir -p "$HOME/.codex"
  if ! grep -q "\[$SKILL_NAME\]" "$CODEX_CFG" 2>/dev/null; then
    cat >> "$CODEX_CFG" << TOML

[mcp_servers.$SKILL_NAME]
command = "$VENV_PYTHON"
args    = ["$ENTRY_ABS"]
TOML
    echo "Registered with Codex -> $CODEX_CFG"
  else
    echo "Already registered with Codex — skipping."
  fi
fi

echo ""
echo "✓ $SKILL_NAME $SKILL_VERSION is ready."
